{
  "name": "cocobase",
  "version": "1.6.0",
  "type": "module",
  "description": "The Official cocobase sdk",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/index.js"
    },
    "./browser": "./dist/browser/cocobase.min.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:browser",
    "build:esm": "tsc",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:browser": "rollup -c rollup.config.js",
    "clean": "rm -rf dist",
    "test": "npm run test:app",
    "test:app": "tsx test/app.ts",
    "test:broadcast": "tsx test/broadcast.ts",
    "prepublishOnly": "npm run build",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lordace-coder/coco_base_js.git"
  },
  "keywords": [
    "baas",
    "backend",
    "api",
    "client",
    "cocobase",
    "database",
    "cloud"
  ],
  "author": "Your Name",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lordace-coder/coco_base_js/issues"
  },
  "homepage": "https://github.com/lordace-coder/coco_base_js#readme",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^22.15.29",
    "nodemon": "^3.1.10",
    "rollup": "^4.41.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
